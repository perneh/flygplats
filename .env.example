# Copy to ".env" in the repo root (docker compose loads it automatically):
#   cp .env.example .env
#
# DISPLAY for the frontend container (Linux Qt → your X11 server).
# Default in compose is host.docker.internal:0 — override here if connection fails.

# macOS + Docker Desktop: try this first (requires XQuartz + TCP; see infra/README.md)
FRONTEND_DISPLAY=host.docker.internal:0

# If you see: "could not connect to display host.docker.internal:0", try your Mac's
# LAN IP instead (same Wi‑Fi interface IP as in System Settings → Network):
# FRONTEND_DISPLAY=192.168.1.23:0

# Linux host with X11: set this (and use: -f infra/docker-compose.linux-x11.yml)
# FRONTEND_DISPLAY=:0
