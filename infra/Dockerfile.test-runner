# syntax=docker/dockerfile:1
# pytest only: Qt libs for pytest-qt offscreen; single pip layer.
FROM python:3.12-slim-bookworm

ENV PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    QT_QPA_PLATFORM=offscreen \
    PYTHONPATH=/app/packages/test_support/src:/app/backend:/app/frontend

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    libgl1 \
    libegl1 \
    libglib2.0-0 \
    libxkbcommon0 \
    libdbus-1-3 \
    libfontconfig1 \
    libfreetype6 \
    libxcb-icccm4 \
    libxcb-image0 \
    libxcb-keysyms1 \
    libxcb-randr0 \
    libxcb-render-util0 \
    libxcb-render0 \
    libxcb-shape0 \
    libxcb-shm0 \
    libxcb-sync1 \
    libxcb-xfixes0 \
    libxcb-xinerama0 \
    libxcb-xkb1 \
    libxcb-cursor0 \
    libxcb-util1 \
    libxkbcommon-x11-0 \
    libxcb1 \
    libx11-6 \
    libx11-xcb1 \
    libxext6 \
    libsm6 \
    && rm -rf /var/lib/apt/lists/* \
    && ldconfig

COPY requirements.test-runner.txt pyproject.toml ./
COPY packages/test_support ./packages/test_support

# Backend: API tests import ``app.main`` (full ASGI app) — ``app/`` is required. Omit alembic/runtime-only files.
COPY backend/requirements-core.txt ./backend/requirements-core.txt
COPY backend/app ./backend/app
COPY backend/tests ./backend/tests
COPY backend/init_data ./backend/init_data

# Frontend: GUI tests only need the package + tests (not full tree).
COPY frontend/requirements-core.txt ./frontend/requirements-core.txt
COPY frontend/golf_desktop ./frontend/golf_desktop
COPY frontend/tests ./frontend/tests

RUN python -m venv /opt/venv \
    && /opt/venv/bin/pip install --upgrade pip \
    && /opt/venv/bin/pip install -r requirements.test-runner.txt \
    && find /opt/venv -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null || true

ENV PATH="/opt/venv/bin:$PATH"
# Uses [tool.pytest.ini_options] addopts in pyproject.toml (per-test PASSED/FAILED, durations, etc.)
# Override when running: -e PYTEST_ADDOPTS=-q

# test_load_scenario.py requires --api-base-url; exclude it from the default batch (run it explicitly).
CMD ["python", "-m", "pytest", "backend/tests", "--ignore=backend/tests/test_load_scenario.py", "frontend/tests"]
